ALPACA_API_KEY=your_key
ALPACA_SECRET_KEY=your_secret
ALPACA_PAPER=true
SYMBOL=BTC/USD
ENABLE_SHORTS=false
DRY_RUN=false
DASHBOARD_ENABLED=true
DASHBOARD_INTERVAL_SECONDS=2
SESSION_START_UTC=00:00
SESSION_END_UTC=23:59
MAX_TRADES_PER_SESSION=100
ORDER_REPRICE_SECONDS=15
FUNDING_RATE_BPS_PER_HOUR=0
MARKET_MAKER_TARGET_SPREAD_BPS=8
MARKET_MAKER_INVENTORY_SKEW_BPS=3
MARKET_MAKER_SIZE_SKEW_FACTOR=0.75
MARKET_MAKER_REPRICE_BPS=1

LOOP_INTERVAL_SECONDS=1.0
STALE_DATA_SECONDS=10

MAX_POSITION_BTC=0.01
MAX_TRADE_NOTIONAL_USD=250
MAX_DAILY_LOSS_USD=50
MAX_CONSECUTIVE_LOSSES=4
COOLDOWN_SECONDS=30

MOMENTUM_LOOKBACK_TICKS=5
SPREAD_BPS_MIN=1.5
TAKE_PROFIT_BPS=4
STOP_LOSS_BPS=3
MAX_HOLDING_SECONDS=30

ORDER_SIZE_BTC=0.001
ORDER_PRICE_OFFSET_BPS=0.5

DB_PATH=runtime/trades.db
LOG_LEVEL=INFO

# Runtime wiring
EXCHANGE=alpaca
FAST_MODE_ENABLED=true
FAST_LOOP_INTERVAL_MS=100

# Optional exchange credentials for future non-Alpaca runtime paths
COINBASE_API_KEY=
COINBASE_SECRET=
COINBASE_PASSPHRASE=
COINBASE_PRODUCT_ID=BTC-USD

# Solo operations defaults
AUTO_OPS_ENABLED=true
DAILY_AUTO_REPORT_ENABLED=true
MAX_FILL_SLIPPAGE_USD=2.5

# Profit controls
MIN_NET_EDGE_BPS=0.35
REGIME_LOOKBACK_TICKS=40
ADVERSE_MOVE_BPS=6.0
ADVERSE_COOLDOWN_SECONDS=2
MIN_FILL_RATIO=0.08
MAX_REJECT_RATIO=0.25
MAX_AVG_SLIPPAGE_USD=2.0
SLIPPAGE_NOTIONAL_FLOOR_USD=100.0
EDGE_FEE_BPS_OVERRIDE=10.0
EDGE_CAPTURE_MULTIPLIER=2.0
INVENTORY_ACCEL_RATIO=0.6
DERISK_SPREAD_MULTIPLIER=1.8
DERISK_SIZE_MULTIPLIER=0.4

# Alerting: disabled | discord | telegram | email
ALERT_CHANNEL=disabled
ALERT_WEBHOOK_URL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
